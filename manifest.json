{
  "manifest_version": 3,
  "name": "New Tab Extension",
  "version": "1.0",
  "description": "Extension pour personnaliser la page des nouveaux onglets",
  "permissions": [
    "tabs",
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}

